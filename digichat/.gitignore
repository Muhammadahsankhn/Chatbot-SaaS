*.pem
*.key
certs/

# ─── AI & DATA (Large Files) ───
# Ignore local database files and heavy AI models
*.db
*.sqlite3
models/
*.bin
*.onnx
*.weights
data/*.json
data/*.csv
!data/sample.json # (Example: keep sample data but ignore the rest)

